# Temper configuration
PORT=4173
TEMPER_MODE=local
# local = in-process x402 facilitator stub + optional Casper anchor when key is set
# live  = use external facilitator URL + real Casper settlement path

# Casper Testnet (optional for live anchoring)
CASPER_RPC_URL=https://node.testnet.casper.network/rpc
CASPER_NETWORK_NAME=casper-test
# Path to PEM secret key (never commit)
CASPER_SECRET_KEY_PATH=
CASPER_KEY_ALGO=ed25519
# Public key hex of the funded testnet account (optional; derived from key when possible)
CASPER_PUBLIC_KEY=

# Live x402 (optional)
X402_FACILITATOR_URL=
X402_PAYEE_ADDRESS=
X402_ASSET_PACKAGE=
X402_ASSET_NAME=Wrapped CSPR
X402_PRICE=0.01
